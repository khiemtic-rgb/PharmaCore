{
  "name": "pharmacore-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "openapi:spec": "powershell -ExecutionPolicy Bypass -File ../../scripts/export-openapi.ps1",
    "openapi:types": "openapi-typescript ./openapi/swagger.json -o ./src/shared/api/generated/api-schema.ts",
    "openapi:sync": "npm run openapi:spec && npm run openapi:types"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.24.2",
    "axios": "^1.8.4",
    "dayjs": "^1.11.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.6.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.2"
  }
}
