# Cloudflare Web Analytics — lượt truy cập novixa.vn (Dashboard → Analytics → Web Analytics → Add site)
PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# Trang /vi/thong-ke — mật khẩu xem thống kê (dùng lúc build, không cần Functions runtime)
STATS_VIEW_KEY=
CF_ZONE_ID=
# Token cần quyền Zone → Analytics → Read
CLOUDFLARE_API_TOKEN=

# Cloudflare Workers AI — Flux Schnell (miễn phí, ưu tiên)
# Dashboard → Workers AI → Use REST API → Create API Token + Account ID
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Tuỳ chọn
# CLOUDFLARE_AI_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
# CLOUDFLARE_AI_STEPS=4

# OpenAI — auto-publish bài + ảnh (scripts/auto-publish-news.mjs, giống Kit Technology)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1
