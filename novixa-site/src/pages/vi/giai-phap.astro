---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FoundingEarlyAccess from '../../components/FoundingEarlyAccess.astro';
import FoundingFaq from '../../components/FoundingFaq.astro';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('vi');
---

<BaseLayout title={m.solutions.title} description={m.solutions.intro} canonicalPath="/vi/giai-phap">
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{m.solutions.title}</h1>
      <p class="section-intro">{m.solutions.intro}</p>
      <div class="card-grid">
        <article class="card">
          <h3>{m.solutions.posTitle}</h3>
          <p>{m.solutions.posDesc}</p>
        </article>
        <article class="card">
          <h3>{m.solutions.invTitle}</h3>
          <p>{m.solutions.invDesc}</p>
        </article>
        <article class="card">
          <h3>{m.solutions.custTitle}</h3>
          <p>{m.solutions.custDesc}</p>
        </article>
        <article class="card">
          <h3>{m.solutions.opsTitle}</h3>
          <p>{m.solutions.opsDesc}</p>
        </article>
        <article class="card">
          <h3>{m.solutions.aiTitle}</h3>
          <p>{m.solutions.aiDesc}</p>
        </article>
      </div>
    </div>
  </section>
  <FoundingEarlyAccess m={m.founding} />
  <FoundingFaq m={m.foundingFaq} />
  <section class="section" style="padding-top: 0">
    <div class="container">
      <p>
        <a class="btn btn-primary" href="/vi/lien-he#contact-form">{m.founding.ctaPrimary}</a>
      </p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
