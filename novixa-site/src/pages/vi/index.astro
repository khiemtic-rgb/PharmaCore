---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import PainSection from '../../components/PainSection.astro';
import SolutionSection from '../../components/SolutionSection.astro';
import DashboardSection from '../../components/DashboardSection.astro';
import WorkflowSection from '../../components/WorkflowSection.astro';
import PlatformSection from '../../components/PlatformSection.astro';
import AISection from '../../components/AISection.astro';
import ScaleSection from '../../components/ScaleSection.astro';
import KnowledgeSection from '../../components/KnowledgeSection.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';
import { sortPublishedNews } from '../../lib/newsDate';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('vi');
const posts = sortPublishedNews(await getCollection('tinTuc')).slice(0, 3);
---

<BaseLayout
  title={m.meta.siteName}
  description={m.meta.description}
  canonicalPath="/vi"
>
  <Header slot="header" />
  <Hero />
  <PainSection />
  <SolutionSection />
  <DashboardSection />
  <WorkflowSection />
  <PlatformSection />
  <AISection />
  <ScaleSection />
  <KnowledgeSection posts={posts} />
  <CTASection />
  <Footer slot="footer" />
</BaseLayout>
