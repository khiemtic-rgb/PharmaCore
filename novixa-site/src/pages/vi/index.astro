---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ValueCardsSection from '../../components/ValueCardsSection.astro';
import AssessmentSection from '../../components/AssessmentSection.astro';
import SolutionSection from '../../components/SolutionSection.astro';
import PricingSection from '../../components/PricingSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import { t } from '../../i18n';
import '../../styles/global.css';
import '../../styles/homepage.css';

const m = t('vi');
---

<BaseLayout
  title={m.meta.siteName}
  description={m.meta.description}
  canonicalPath="/vi"
>
  <Header slot="header" />

  <div class="home-page">
    <div class="hp-fold">
      <div class="hp-hero-wrap">
        <div class="container">
          <Hero />
        </div>
      </div>
    </div>

    <ValueCardsSection />

    <AssessmentSection />
    <SolutionSection />
    <PricingSection />
    <FaqSection home />
  </div>

  <Footer slot="footer" />
</BaseLayout>
