---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ValueCardsSection from '../../components/ValueCardsSection.astro';
import AssessmentSection from '../../components/AssessmentSection.astro';
import SolutionSection from '../../components/SolutionSection.astro';
import PricingSection from '../../components/PricingSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import CTASection from '../../components/CTASection.astro';
import { t } from '../../i18n';
import '../../styles/global.css';
import '../../styles/homepage.css';

const m = t('vi');
---

<BaseLayout
  title={m.meta.siteName}
  description={m.meta.description}
  canonicalPath="/vi"
>
  <Header slot="header" />

  <div class="home-page">
    <div class="hp-hero-block">
      <div class="container">
        <Hero />
        <ValueCardsSection />
      </div>
    </div>

    <AssessmentSection />
    <SolutionSection />
    <PricingSection />
    <FaqSection />
    <CTASection />
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const reveals = document.querySelectorAll('.hp-reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  reveals.forEach((el) => observer.observe(el));
</script>
