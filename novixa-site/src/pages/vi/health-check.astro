---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HealthCheckHeader from '../../components/health-check/HealthCheckHeader.astro';
import HealthCheckFooter from '../../components/health-check/HealthCheckFooter.astro';
import HealthCheckDeliverableIcon from '../../components/health-check/HealthCheckDeliverableIcon.astro';
import HealthCheckProcessIcon from '../../components/health-check/HealthCheckProcessIcon.astro';
import '../../styles/global.css';
import '../../styles/health-check.css';

const assessmentUrl = 'https://survey.novixa.vn';

const title = 'Kiểm tra sức khỏe nhà thuốc';
const description =
  'Chỉ 7 phút để biết nhà thuốc của bạn đang khỏe hay đang mất lợi nhuận mà chưa nhận ra. Đánh giá miễn phí, nhận báo cáo PDF chuyên sâu.';

const heroFeatures = [
  { icon: 'clock', title: '7 phút', desc: '30 câu hỏi' },
  { icon: 'brain', title: 'AI phân tích', desc: 'Chính xác' },
  { icon: 'pdf', title: 'Báo cáo PDF', desc: 'Chuyên sâu' },
  { icon: 'expert', title: 'Tư vấn 1-1', desc: 'Cùng chuyên gia' },
];

const deliverables: Array<{
  icon: 'gauge' | 'report' | 'swot' | 'roadmap' | 'consulting';
  title: string;
  desc: string;
}> = [
  { icon: 'gauge', title: 'Điểm sức khỏe nhà thuốc', desc: 'Đánh giá mức độ trưởng thành theo thang điểm quốc tế' },
  { icon: 'report', title: 'Báo cáo AI chuyên sâu', desc: 'Phân tích điểm mạnh, điểm yếu, rủi ro và cơ hội cải thiện' },
  { icon: 'swot', title: 'SWOT Analysis', desc: 'Phân tích mô hình SWOT cho nhà thuốc của bạn' },
  { icon: 'roadmap', title: 'Roadmap 90 ngày', desc: 'Lộ trình cải thiện ưu tiên theo từng giai đoạn' },
  { icon: 'consulting', title: 'Tư vấn cùng chuyên gia', desc: 'Buổi tư vấn 1-1 để giải đáp và xây dựng kế hoạch phù hợp' },
];

const steps: Array<{
  title: string;
  desc: string;
  icon: 'questions' | 'brain' | 'pdf' | 'expert' | 'target';
}> = [
  { title: 'Trả lời 30 câu hỏi', desc: 'Khoảng 7 phút', icon: 'questions' },
  { title: 'AI phân tích & chấm điểm', desc: 'Tự động & chính xác', icon: 'brain' },
  { title: 'Nhận báo cáo PDF', desc: 'Tư vấn chuyên sâu với Dashboard, SWOT và Roadmap', icon: 'pdf' },
  { title: 'Tư vấn 1-1', desc: 'Cùng chuyên gia phân tích kết quả và giải đáp', icon: 'expert' },
  { title: 'Lộ trình cải thiện', desc: 'Đề xuất giải pháp phù hợp với nhà thuốc của bạn', icon: 'target' },
];

const reportItems = [
  'Dashboard trực quan',
  'Phân tích chi tiết từng lĩnh vực',
  'So sánh với mức trung bình ngành',
  'Khuyến nghị cụ thể, dễ triển khai',
];
---

<BaseLayout title={title} description={description} canonicalPath="/vi/health-check">
  <HealthCheckHeader slot="header" />

  <div class="hc-page">
    <section class="hc-hero">
      <div class="hc-container">
        <div class="hc-hero__grid">
        <div class="hc-hero__content">
          <h1 class="hc-hero__title">
            KIỂM TRA<br />
            <span>SỨC KHỎE</span><br />
            NHÀ THUỐC
          </h1>
          <p class="hc-hero__subtitle">
            Chỉ 7 phút để biết nhà thuốc của bạn đang khỏe hay đang mất lợi nhuận mà chưa nhận ra.
          </p>

          <div class="hc-hero__features">
            {
              heroFeatures.map((f) => (
                <div class="hc-hero__feature">
                  <span class="hc-hero__feature-icon" aria-hidden="true">
                    {f.icon === 'clock' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                        <circle cx="12" cy="12" r="9" />
                        <path d="M12 7v5l3 2" stroke-linecap="round" />
                      </svg>
                    )}
                    {f.icon === 'brain' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                        <path d="M9 5a3 3 0 00-3 3v1a2 2 0 01-2 2 2 2 0 000 4 2 2 0 012 2v1a3 3 0 003 3" />
                        <path d="M15 5a3 3 0 013 3v1a2 2 0 012 2 2 2 0 010 4 2 2 0 01-2 2v1a3 3 0 01-3 3" />
                      </svg>
                    )}
                    {f.icon === 'pdf' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                        <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" />
                        <path d="M14 3v5h5" />
                      </svg>
                    )}
                    {f.icon === 'expert' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                        <circle cx="12" cy="9" r="3" />
                        <path d="M6 19c0-2.8 2.7-5 6-5s6 2.2 6 5" />
                      </svg>
                    )}
                  </span>
                  <span class="hc-hero__feature-text">
                    <strong>{f.title}</strong>
                    <small>{f.desc}</small>
                  </span>
                </div>
              ))
            }
          </div>

          <a class="hc-btn-primary" href={assessmentUrl}>
            BẮT ĐẦU ĐÁNH GIÁ MIỄN PHÍ
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <p class="hc-hero__trust">
            Hoàn toàn miễn phí • Không cần thẻ tín dụng • Bảo mật thông tin
          </p>
        </div>

        <div class="hc-hero__visual" aria-hidden="true">
          <div class="hc-dashboard">
            <article class="hc-dashboard__card hc-dashboard__card--score">
              <span class="hc-float__label">Điểm sức khỏe tổng thể</span>
              <div class="hc-float__score"><strong>72</strong><span>/100</span></div>
              <div class="hc-float__bar"><span style="width:72%"></span></div>
              <small>Level 3 — Đang phát triển</small>
            </article>

            <article class="hc-dashboard__card hc-dashboard__card--radar">
              <span class="hc-float__label">Phân tích 6 lĩnh vực</span>
              <svg viewBox="0 0 140 110" fill="none" class="hc-float__radar">
                <polygon points="70,14 110,38 102,78 70,94 38,78 30,38" fill="rgba(25,195,125,0.1)" stroke="#e2e8f0" />
                <polygon points="70,26 96,44 90,72 70,82 50,72 44,44" fill="rgba(25,195,125,0.28)" stroke="#19c37d" stroke-width="1.5" />
                <text x="70" y="8" text-anchor="middle" fill="#64748b" font-size="6">Tài chính</text>
                <text x="118" y="40" text-anchor="start" fill="#64748b" font-size="6">Bán hàng</text>
                <text x="108" y="88" text-anchor="start" fill="#64748b" font-size="6">Tồn kho</text>
                <text x="70" y="106" text-anchor="middle" fill="#64748b" font-size="6">Vận hành</text>
                <text x="12" y="88" text-anchor="end" fill="#64748b" font-size="6">Khách hàng</text>
                <text x="8" y="40" text-anchor="end" fill="#64748b" font-size="6">Nhân sự</text>
              </svg>
            </article>

            <article class="hc-dashboard__card hc-dashboard__card--trend">
              <span class="hc-float__label">Xu hướng lợi nhuận</span>
              <strong class="hc-float__trend">+18.6% so với kỳ trước</strong>
              <svg viewBox="0 0 140 44" preserveAspectRatio="none" class="hc-float__chart">
                <defs>
                  <linearGradient id="hcChartFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#19c37d" stop-opacity="0.25" />
                    <stop offset="100%" stop-color="#19c37d" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <polygon points="0,36 24,28 48,32 72,18 96,24 120,12 140,16 140,44 0,44" fill="url(#hcChartFill)" />
                <polyline points="0,36 24,28 48,32 72,18 96,24 120,12 140,16" fill="none" stroke="#19c37d" stroke-width="2" stroke-linecap="round" />
              </svg>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="hc-section hc-deliverables">
      <div class="hc-container">
        <h2 class="hc-section__title">Bạn sẽ nhận được gì?</h2>
        <div class="hc-cards">
          {
            deliverables.map((card) => (
              <article class="hc-card">
                <HealthCheckDeliverableIcon name={card.icon} />
                <h3>{card.title}</h3>
                <p>{card.desc}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="hc-section hc-process">
      <div class="hc-container">
        <h2 class="hc-section__title">Quy trình 5 bước đơn giản</h2>
        <div class="hc-process__flow" aria-label="Quy trình 5 bước">
          {
            steps.map((step, i) => (
              <>
                {i > 0 && (
                  <span class="hc-process__connector" aria-hidden="true">
                    <svg viewBox="0 0 40 8" fill="none"><line x1="0" y1="4" x2="30" y2="4" stroke="#19c37d" stroke-width="1.5" stroke-dasharray="4 3" /><path d="M33 1l4 3-4 3" stroke="#19c37d" stroke-width="1.5" stroke-linecap="round" /></svg>
                  </span>
                )}
                <div class="hc-process__step">
                  <div class="hc-process__card">
                    <HealthCheckProcessIcon name={step.icon} />
                    <span class="hc-process__num">{i + 1}</span>
                  </div>
                  <span class="hc-process__title">{step.title}</span>
                  <span class="hc-process__desc">{step.desc}</span>
                </div>
              </>
            ))
          }
        </div>
      </div>
    </section>

    <section class="hc-section hc-report">
      <div class="hc-container hc-report__grid">
        <div class="hc-report__copy">
          <h2 class="hc-report__title">
            Báo cáo của bạn sẽ như <span class="hc-report__accent">thế này</span>
          </h2>
          <ul class="hc-report__list">
            {reportItems.map((item) => (
              <li>
                <span class="hc-report__check" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2.5 6l2.5 2.5 4.5-5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="hc-report__stack" aria-hidden="true">
          <div class="hc-pdf hc-pdf--dashboard">
            <span class="hc-float__label">Tổng quan kết quả</span>
            <div class="hc-float__score"><strong>72</strong><span>/100</span></div>
            <span class="hc-pdf__level">Level 3</span>
            <svg viewBox="0 0 140 100" fill="none" class="hc-pdf__radar">
              <polygon points="70,12 108,32 98,72 70,86 42,72 32,32" fill="rgba(25,195,125,0.2)" stroke="#19c37d" stroke-width="1.5" />
              <circle cx="70" cy="49" r="3" fill="#19c37d" />
              <text x="70" y="8" text-anchor="middle" fill="#94a3b8" font-size="7" font-family="Inter,system-ui,sans-serif">Tài chính</text>
              <text x="115" y="34" fill="#94a3b8" font-size="7" font-family="Inter,system-ui,sans-serif">Bán hàng</text>
              <text x="102" y="82" fill="#94a3b8" font-size="7" font-family="Inter,system-ui,sans-serif">Vận hành</text>
              <text x="38" y="82" fill="#94a3b8" font-size="7" font-family="Inter,system-ui,sans-serif">Nhân sự</text>
              <text x="22" y="34" fill="#94a3b8" font-size="7" font-family="Inter,system-ui,sans-serif">Kho</text>
            </svg>
          </div>

          <div class="hc-pdf hc-pdf--analysis">
            <span class="hc-float__label">SWOT Analysis</span>
            <div class="hc-swot-grid">
              <span class="hc-swot-grid__s">S</span>
              <span class="hc-swot-grid__w">W</span>
              <span class="hc-swot-grid__o">O</span>
              <span class="hc-swot-grid__t">T</span>
            </div>
            <span class="hc-float__label hc-pdf__roadmap-label">Roadmap 90 ngày</span>
            <div class="hc-roadmap">
              <div class="hc-roadmap__track">
                <span class="hc-roadmap__dot"></span>
                <span class="hc-roadmap__dot"></span>
                <span class="hc-roadmap__dot hc-roadmap__dot--active"></span>
              </div>
              <div class="hc-roadmap__labels">
                <span>30 ngày</span>
                <span>60 ngày</span>
                <span>90 ngày</span>
              </div>
            </div>
          </div>

          <div class="hc-pdf hc-pdf--cover">
            <div class="hc-pdf-cover__top">
              <span class="hc-pdf-cover__badge">AI HEALTH CHECK</span>
              <p class="hc-pdf-cover__title">
                BÁO CÁO ĐÁNH GIÁ<br />
                <span>SỨC KHỎE</span> NHÀ THUỐC
              </p>
              <svg viewBox="0 0 120 32" fill="none" class="hc-pdf-cover__illus" aria-hidden="true">
                <rect x="8" y="14" width="18" height="16" rx="2" fill="rgba(255,255,255,0.15)" />
                <rect x="30" y="10" width="22" height="20" rx="2" fill="rgba(255,255,255,0.22)" />
                <rect x="56" y="14" width="18" height="16" rx="2" fill="rgba(255,255,255,0.15)" />
                <rect x="78" y="8" width="24" height="22" rx="2" fill="rgba(255,255,255,0.28)" />
                <path d="M4 30h112" stroke="rgba(255,255,255,0.2)" stroke-width="1" />
              </svg>
            </div>
            <div class="hc-pdf-cover__bottom">
              <img src="/images/logo.png" alt="" width="28" height="28" />
              <strong>NOVIXA</strong>
              <small>Ngày đánh giá: 25/08/2024</small>
              <small>Mã báo cáo: HC - 2024-0825-001</small>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="hc-section hc-social">
      <div class="hc-container">
        <div class="hc-social__box">
          <p><strong>Đang triển khai chương trình đánh giá miễn phí</strong> cho các nhà thuốc trên toàn quốc.</p>
        </div>
      </div>
    </section>

    <section class="hc-final-cta">
      <div class="hc-container">
        <div class="hc-final-cta__banner">
          <div class="hc-final-cta__left">
            <span class="hc-final-cta__gift" aria-hidden="true">
              <svg viewBox="0 0 72 72" fill="none" class="hc-final-cta__gift-svg">
                <rect x="14" y="30" width="44" height="34" rx="4" fill="#fff" />
                <path d="M14 38h44" stroke="#19c37d" stroke-width="5" />
                <rect x="32" y="30" width="8" height="34" fill="#19c37d" />
                <path d="M22 30c0-6 6-10 14-10s14 4 14 10" stroke="#19c37d" stroke-width="4" stroke-linecap="round" />
                <ellipse cx="36" cy="22" rx="10" ry="7" fill="#19c37d" />
                <path d="M30 22c2-4 6-6 6-6s4 2 6 6" stroke="#15a86d" stroke-width="2" stroke-linecap="round" />
                <path d="M10 64 L18 30 L26 64 Z" fill="rgba(255,255,255,0.15)" />
                <path d="M62 64 L54 30 L46 64 Z" fill="rgba(0,0,0,0.06)" />
              </svg>
            </span>
            <div class="hc-final-cta__text">
              <p class="hc-final-cta__headline">
                Miễn phí <strong>100 báo cáo</strong> đầu tiên
              </p>
              <span>cho các nhà thuốc đăng ký sớm nhất!</span>
            </div>
          </div>
          <div class="hc-final-cta__action">
            <a class="hc-btn-white" href={assessmentUrl}>
              BẮT ĐẦU ĐÁNH GIÁ NGAY
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </a>
            <span class="hc-final-cta__url">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
                <circle cx="8" cy="8" r="6.5" />
                <path d="M2 8h12M8 2c2 2.5 3 5 3 6s-1 3.5-3 6M8 2c-2 2.5-3 5-3 6s1 3.5 3 6" stroke-linecap="round" />
              </svg>
              www.novixa.vn/health-check
            </span>
          </div>
        </div>
      </div>
    </section>
  </div>

  <HealthCheckFooter slot="footer" />
</BaseLayout>
