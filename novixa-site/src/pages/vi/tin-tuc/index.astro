---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { sortPublishedNews } from '../../../lib/newsDate';
import NewsListItem from '../../../components/NewsListItem.astro';
import { t } from '../../../i18n';
import '../../../styles/global.css';

const m = t('vi');
const posts = sortPublishedNews(await getCollection('tinTuc'));
---

<BaseLayout title={m.news.title} description={m.news.intro}>
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{m.news.title}</h1>
      <p class="section-intro">{m.news.intro}</p>
      <ul class="news-list">
        {
          posts.map((post) => (
            <NewsListItem
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              newLabel={m.news.newBadge}
            />
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
