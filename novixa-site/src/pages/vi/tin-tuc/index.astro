---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n';
import '../../../styles/global.css';

const m = t('vi');
const posts = (await getCollection('tinTuc'))
  .filter((p) => p.data.lang === 'vi')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = new Intl.DateTimeFormat('vi-VN', { dateStyle: 'medium' });
---

<BaseLayout title={m.news.title} description={m.news.intro}>
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{m.news.title}</h1>
      <p class="section-intro">{m.news.intro}</p>
      <ul class="news-list">
        {
          posts.map((post) => (
            <li>
              <a href={`/vi/tin-tuc/${post.id}`}>{post.data.title}</a>
              <p class="news-meta">{fmt.format(post.data.pubDate)} — {post.data.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
