---
import { t } from '../i18n';

const m = t('vi');
const base = '/vi';
const path = Astro.url.pathname;

const links = [
  { href: `${base}#giai-phap`, label: m.nav.platform },
  { href: `${base}#giai-phap`, label: m.nav.solutions },
  { href: `${base}#danh-gia`, label: m.nav.customers },
  { href: `${base}/tin-tuc`, label: m.nav.news, active: path.startsWith(`${base}/tin-tuc`) },
  { href: `${base}/ve-chung-toi`, label: m.nav.about, active: path.startsWith(`${base}/ve-chung-toi`) },
];
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a href={base} class="logo">
      <span class="logo-crop" aria-hidden="true">
        <img class="logo-img" src="/images/logo.png" alt="" width="160" height="160" decoding="async" />
      </span>
      <span class="logo-stack">
        <span class="logo-text">NOVIXA</span>
        <span class="logo-tagline">Quản trị nhà thuốc thông minh</span>
      </span>
    </a>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      data-nav-toggle
    >
      <span class="sr-only">{m.nav.menuOpen}</span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>

    <nav id="site-nav" class="nav" data-nav aria-label="Menu chính">
      {
        links.map((link) => (
          <a href={link.href} class:list={{ active: link.active }}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <a href="https://app.novixa.vn" class="nav-login">{m.nav.login}</a>
      <a href="/vi/lien-he" class="nav-cta">{m.nav.demo}</a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');
  const syncHeader = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 12);
  };

  syncHeader();
  window.addEventListener('scroll', syncHeader, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .site-header {
    background: rgba(255, 255, 255, 0.85);
    border-bottom: 1px solid #e8eef3;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 300ms ease, box-shadow 300ms ease;
  }

  .site-header.is-scrolled,
  .site-header:has(.nav.is-open) {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 4px 24px rgba(15, 39, 71, 0.06);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    justify-self: start;
  }

  .logo:hover {
    text-decoration: none;
  }

  .logo-crop {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 32px;
    height: 32px;
    border-radius: 8px;
  }

  .logo-img {
    width: 48px;
    height: 48px;
    max-width: none;
    object-fit: contain;
  }

  .logo-stack {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .logo-text {
    color: #0f2747;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .logo-tagline {
    color: #64748b;
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid #e8eef3;
    border-radius: 10px;
    background: #fff;
    cursor: pointer;
    justify-self: end;
    grid-column: 3;
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    margin-inline: auto;
    background: #0f2747;
    border-radius: 2px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    font-size: 0.875rem;
    font-weight: 600;
    grid-column: 2;
  }

  .nav a {
    color: #64748b;
    text-decoration: none;
    padding: 0.35rem 0;
    transition: color 300ms ease;
    white-space: nowrap;
  }

  .nav a:hover,
  .nav a.active {
    color: #0f2747;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    justify-self: end;
    grid-column: 3;
  }

  .nav-login {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 1rem;
    border: 1.5px solid #e8eef3;
    border-radius: 10px;
    color: #0f2747 !important;
    font-size: 0.875rem;
    font-weight: 600;
    background: #fff;
    text-decoration: none;
    transition: border-color 300ms ease;
  }

  .nav-login:hover {
    border-color: #cbd5e1;
    text-decoration: none;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 1.1rem;
    border-radius: 10px;
    background: #18c37e;
    color: #fff !important;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(24, 195, 126, 0.25);
    transition: background 300ms ease, transform 300ms ease;
  }

  .nav-cta:hover {
    background: #14a86d;
    transform: scale(1.02);
    text-decoration: none;
  }

  @media (max-width: 992px) {
    .header-inner {
      grid-template-columns: 1fr auto;
    }

    .nav-toggle {
      display: flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.75rem 1rem;
      background: #fff;
      border-bottom: 1px solid #e8eef3;
      box-shadow: 0 8px 24px rgba(15, 39, 71, 0.08);
      grid-column: 1 / -1;
    }

    .nav.is-open {
      display: flex;
    }

    .nav a {
      padding: 0.75rem 0;
      border-bottom: 1px solid #e8eef3;
    }

    .nav-actions {
      display: none;
    }

    .header-inner {
      position: relative;
    }
  }
</style>
