---
const modules = [
  { title: 'POS bán hàng', desc: 'Bán hàng nhanh tại quầy, đồng bộ doanh thu và tồn kho theo thời gian thực.', icon: 'pos', tone: 'green' },
  { title: 'Kho FEFO', desc: 'Theo dõi lô, hạn dùng và cảnh báo hàng cận date — giảm thất thoát tồn kho.', icon: 'warehouse', tone: 'green' },
  { title: 'CRM khách hàng', desc: 'Chăm sóc khách hàng, tích điểm và tăng tỷ lệ quay lại mua thuốc.', icon: 'crm', tone: 'teal' },
  { title: 'Dashboard', desc: 'Theo dõi doanh thu, lợi nhuận và KPI vận hành trên một màn hình.', icon: 'dashboard', tone: 'blue' },
  { title: 'App khách hàng', desc: 'Đặt thuốc, nhắc uống thuốc và tích điểm — giữ chân khách hàng trung thành.', icon: 'app', tone: 'purple' },
  { title: 'AI Copilot', desc: 'Gợi ý nhập hàng, phân tích xu hướng và hỗ trợ ra quyết định vận hành.', icon: 'ai', tone: 'orange' },
];
---

<section class="hp-modules" id="giai-phap" aria-labelledby="modules-title">
  <div class="container">
    <div class="hp-section-head hp-reveal">
      <h2 id="modules-title">Một nền tảng.<br />Mọi nghiệp vụ.</h2>
    </div>

    <div class="hp-modules__grid">
      {
        modules.map((mod) => (
          <article class="hp-module-card hp-reveal">
            <span class:list={['hp-module-card__icon', `hp-module-card__icon--${mod.tone}`]} aria-hidden="true">
              {mod.icon === 'pos' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <rect x="3" y="6" width="18" height="13" rx="2" />
                  <path d="M7 11h10M7 15h6" />
                </svg>
              )}
              {mod.icon === 'warehouse' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <path d="M3 9l9-5 9 5v11H3V9z" stroke-linejoin="round" />
                  <path d="M9 20v-6h6v6" />
                </svg>
              )}
              {mod.icon === 'crm' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <circle cx="12" cy="8" r="4" />
                  <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                </svg>
              )}
              {mod.icon === 'dashboard' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <rect x="3" y="3" width="7" height="9" rx="1" />
                  <rect x="14" y="3" width="7" height="5" rx="1" />
                  <rect x="14" y="12" width="7" height="9" rx="1" />
                  <rect x="3" y="16" width="7" height="5" rx="1" />
                </svg>
              )}
              {mod.icon === 'app' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <rect x="7" y="2" width="10" height="20" rx="2" />
                  <circle cx="12" cy="18" r="0.5" fill="currentColor" />
                </svg>
              )}
              {mod.icon === 'ai' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z" />
                  <path d="M5 19l1 3 1-3 3-1-3-1-1-3-1 3-3 1 3 1z" />
                </svg>
              )}
            </span>
            <h3>{mod.title}</h3>
            <p>{mod.desc}</p>
            <a class="hp-module-card__link" href="https://survey.novixa.vn">Tìm hiểu thêm →</a>
          </article>
        ))
      }
    </div>
  </div>
</section>
