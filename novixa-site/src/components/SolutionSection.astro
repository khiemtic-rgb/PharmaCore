---
const modules = [
  { title: 'POS', icon: '▦', lines: ['Bán hàng nhanh.', 'Đồng bộ doanh thu.'] },
  { title: 'Kho', icon: '◆', lines: ['Theo dõi theo lô.', 'Cảnh báo cận date.'] },
  { title: 'CRM', icon: '●●', lines: ['Chăm sóc khách hàng.', 'Tăng tỷ lệ quay lại.'] },
  { title: 'Dashboard', icon: '▥', lines: ['Theo dõi mọi chỉ số.', 'Theo thời gian thực.'] },
  { title: 'App khách hàng', icon: '▣', lines: ['Đặt thuốc & tích điểm.', 'Giữ chân khách hàng.'] },
  { title: 'AI Copilot', icon: '✦', lines: ['Gợi ý nhập hàng.', 'Phân tích thông minh.'] },
];
---

<section class="section solution-section" id="giai-phap">
  <div class="container">
    <div class="section-heading center compact-heading">
      <p class="eyebrow">Modules</p>
      <h2>Một nền tảng. Mọi nghiệp vụ.</h2>
    </div>

    <div class="card-grid solution-grid modules-grid">
      {
        modules.map((module) => (
          <article class="card solution-card module-card">
            <div class="module-icon">{module.icon}</div>
            <h3>{module.title}</h3>
            {module.lines.map((line) => <p>{line}</p>)}
          </article>
        ))
      }
    </div>
  </div>
</section>
