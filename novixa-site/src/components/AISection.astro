---
const chatMessages = [
  { role: 'user', text: 'Thuốc Paracetamol còn bao nhiêu lô sắp hết hạn?' },
  { role: 'ai', text: 'Có 3 lô Paracetamol 500mg hết hạn trong 60 ngày tới. Bạn nên ưu tiên xuất kho theo FEFO.' },
  { role: 'user', text: 'Gợi ý nhập hàng tuần này?' },
  { role: 'ai', text: 'Dựa trên tốc độ bán 30 ngày, nên nhập thêm Vitamin C và Oresol. Chi tiết trong báo cáo tuần.' },
];
---

<section class="section ai-section" id="ai-copilot">
  <div class="container ai-grid">
    <div class="section-heading">
      <p class="eyebrow">AI Copilot</p>
      <h2>Trợ lý thông minh cho nhà thuốc.</h2>
      <p>
        Hỏi đáp tức thì về tồn kho, doanh thu và vận hành — không thay thế dược sĩ, mà giúp ra quyết định nhanh hơn.
      </p>
    </div>

    <div class="ai-chat" aria-label="Giao diện AI Copilot">
      <div class="ai-chat-header">
        <span class="ai-chat-dot"></span>
        Novixa Copilot
      </div>
      <div class="ai-chat-body">
        {
          chatMessages.map((msg) => (
            <div class:list={['ai-chat-bubble', msg.role === 'ai' ? 'is-ai' : 'is-user']}>
              {msg.text}
            </div>
          ))
        }
      </div>
      <div class="ai-chat-input" aria-hidden="true">
        <span>Hỏi Novixa bất cứ điều gì...</span>
      </div>
    </div>
  </div>
</section>
