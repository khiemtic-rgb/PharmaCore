---
interface Props {
  compact?: boolean;
  variant?: 'hero' | 'dashboard' | 'scale' | 'phone';
}

const { compact = false, variant = 'dashboard' } = Astro.props;

const heroMetrics = [
  { label: 'Doanh thu hôm nay', value: '25.450.000đ', trend: '+12,5%', icon: 'revenue', tone: 'green' },
  { label: 'Số đơn hàng', value: '346', trend: '+8,2%', icon: 'orders', tone: 'blue' },
  { label: 'Lợi nhuận', value: '5.250.000đ', trend: '+15,3%', icon: 'profit', tone: 'purple' },
  { label: 'Tồn kho', value: '1.245', trend: '+3,1%', icon: 'stock', tone: 'orange' },
];

const sidebarItems = [
  { label: 'Tổng quan', active: true, icon: 'overview' },
  { label: 'Bán hàng', icon: 'sales' },
  { label: 'Kho hàng', icon: 'stock' },
  { label: 'Khách hàng', icon: 'customers' },
  { label: 'Báo cáo', icon: 'reports' },
  { label: 'Cài đặt', icon: 'settings' },
];

const linePoints = '4,52 28,38 52,44 76,24 100,30 124,14 148,20';

const donutSegments = [
  { label: 'Đã giao', pct: 72, color: '#16c784' },
  { label: 'Đang giao', pct: 18, color: '#0f7fd0' },
  { label: 'Đã hủy', pct: 10, color: '#cbd5e1' },
];

const defaultMetrics = compact
  ? [
      { label: 'Doanh thu', value: '128tr', trend: '+18%' },
      { label: 'Cận date', value: '34', trend: '-12%' },
      { label: 'Quay lại', value: '42%', trend: '+9%' },
    ]
  : [
      { label: 'Doanh thu hôm nay', value: '128,4tr', trend: '+18%' },
      { label: 'Tồn kho an toàn', value: '92%', trend: '+6%' },
      { label: 'Khách quay lại', value: '42%', trend: '+9%' },
      { label: 'Cảnh báo FEFO', value: '34', trend: '-12%' },
    ];

const metrics = variant === 'hero' || variant === 'phone' ? heroMetrics : defaultMetrics;
---

{
  variant === 'phone' ? (
    <div class="dashboard-preview dashboard-preview--phone">
      <div class="phone-dash-header">
        <strong>Tổng quan</strong>
        <span class="dashboard-status">Live</span>
      </div>
      <div class="phone-dash-metric">
        <span>Doanh thu hôm nay</span>
        <strong>25.450.000đ</strong>
        <small>+12,5%</small>
      </div>
      <div class="phone-dash-grid">
        {heroMetrics.slice(1).map((m) => (
          <article>
            <span>{m.label}</span>
            <strong>{m.value}</strong>
          </article>
        ))}
      </div>
    </div>
  ) : variant === 'hero' ? (
    <div class="dashboard-preview dashboard-preview--hero is-compact">
      <div class="dashboard-hero-layout">
        <aside class="dashboard-sidebar" aria-label="Menu điều hướng">
          <div class="dashboard-sidebar-logo">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 4h12v16H6V4z" fill="url(#novixaGrad)" />
              <defs>
                <linearGradient id="novixaGrad" x1="6" y1="4" x2="18" y2="20">
                  <stop stop-color="#16c784" />
                  <stop offset="1" stop-color="#0f7fd0" />
                </linearGradient>
              </defs>
            </svg>
          </div>
          <nav>
            {sidebarItems.map((item) => (
              <span class:list={['sidebar-item', { active: item.active }]} title={item.label}>
                <span class={`sidebar-icon sidebar-icon--${item.icon}`} aria-hidden="true">
                  {item.icon === 'overview' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <rect x="3" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                      <rect x="11" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                      <rect x="3" y="11" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                      <rect x="11" y="11" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                  )}
                  {item.icon === 'sales' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <path d="M4 6h12l-1.5 9H5.5L4 6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                      <path d="M8 6V4a2 2 0 014 0v2" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                  )}
                  {item.icon === 'stock' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <path d="M4 7l6-3 6 3v9H4V7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.icon === 'customers' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <circle cx="10" cy="7" r="2.5" stroke="currentColor" stroke-width="1.4" />
                      <path d="M5 15c0-2.5 2.2-4 5-4s5 1.5 5 4" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                  )}
                  {item.icon === 'reports' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <path d="M4 15V9l4-2 4 2 4-2v8" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.icon === 'settings' && (
                    <svg viewBox="0 0 20 20" fill="none">
                      <circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.4" />
                      <path d="M10 3v2M10 15v2M3 10h2M15 10h2M5.5 5.5l1.4 1.4M13.1 13.1l1.4 1.4M5.5 14.5l1.4-1.4M13.1 6.9l1.4-1.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                  )}
                </span>
              </span>
            ))}
          </nav>
        </aside>

        <div class="dashboard-main">
          <div class="dashboard-main-header">
            <strong>Tổng quan hoạt động</strong>
            <span class="dashboard-status">Live</span>
          </div>

          <div class="dashboard-metrics dashboard-metrics--hero">
            {metrics.map((metric) => (
              <article class={`kpi-card kpi-card--${metric.tone}`}>
                <span class="kpi-icon" aria-hidden="true">
                  {metric.icon === 'revenue' && (
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M8 3v10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" /></svg>
                  )}
                  {metric.icon === 'orders' && (
                    <svg viewBox="0 0 16 16" fill="none"><rect x="3" y="4" width="10" height="8" rx="1" stroke="currentColor" stroke-width="1.4" /><path d="M6 4V3h4v1" stroke="currentColor" stroke-width="1.4" /></svg>
                  )}
                  {metric.icon === 'profit' && (
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 12l4-5 3 3 3-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  )}
                  {metric.icon === 'stock' && (
                    <svg viewBox="0 0 16 16" fill="none"><path d="M2 6l6-3 6 3v7H2V6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" /></svg>
                  )}
                </span>
                <div class="kpi-body">
                  <span>{metric.label}</span>
                  <strong>{metric.value}</strong>
                  <small>{metric.trend}</small>
                </div>
              </article>
            ))}
          </div>

          <div class="dashboard-charts">
            <div class="dashboard-line-chart" aria-label="Doanh thu 7 ngày qua">
              <span class="chart-title">Doanh thu 7 ngày qua</span>
              <svg viewBox="0 0 152 60" class="line-chart-svg" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="lineFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#16c784" stop-opacity="0.25" />
                    <stop offset="100%" stop-color="#16c784" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <line x1="0" y1="15" x2="152" y2="15" stroke="#e8eef5" stroke-width="1" />
                <line x1="0" y1="30" x2="152" y2="30" stroke="#e8eef5" stroke-width="1" />
                <line x1="0" y1="45" x2="152" y2="45" stroke="#e8eef5" stroke-width="1" />
                <polygon points={`${linePoints} 148,58 4,58`} fill="url(#lineFill)" />
                <polyline points={linePoints} fill="none" stroke="#16c784" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="124" cy="14" r="3.5" fill="#16c784" stroke="#fff" stroke-width="2" />
              </svg>
            </div>

            <div class="dashboard-donut" aria-label="Tỷ lệ đơn hàng">
              <span class="chart-title">Tỷ lệ đơn hàng</span>
              <div class="donut-wrap">
                <div class="donut-chart">
                  <svg viewBox="0 0 80 80" class="donut-svg">
                    <circle cx="40" cy="40" r="28" fill="none" stroke="#e2e8f0" stroke-width="10" />
                    <circle cx="40" cy="40" r="28" fill="none" stroke="#16c784" stroke-width="10" stroke-dasharray="126.6 175.9" stroke-dashoffset="0" transform="rotate(-90 40 40)" />
                    <circle cx="40" cy="40" r="28" fill="none" stroke="#0f7fd0" stroke-width="10" stroke-dasharray="31.6 271" stroke-dashoffset="-126.6" transform="rotate(-90 40 40)" />
                  </svg>
                  <span class="donut-center">72%</span>
                </div>
                <div class="donut-legend">
                  {donutSegments.map((seg) => (
                    <span>
                      <i style={`background:${seg.color}`} />
                      {seg.pct}% {seg.label}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class:list={['dashboard-preview', `dashboard-preview--${variant}`, { 'is-compact': compact }]}>
      <div class="dashboard-topbar">
        <div>
          <span class="dashboard-kicker">Novixa Operating Dashboard</span>
          <strong>Toàn hệ thống</strong>
        </div>
        <span class="dashboard-status">Live</span>
      </div>

      <div class="dashboard-metrics">
        {metrics.map((metric) => (
          <article>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
            <small>{metric.trend}</small>
          </article>
        ))}
      </div>

      <div class="dashboard-body">
        <div class="dashboard-chart" aria-label="Biểu đồ doanh thu và tồn kho">
          <span style="height: 42%" />
          <span style="height: 64%" />
          <span style="height: 52%" />
          <span style="height: 76%" />
          <span style="height: 68%" />
          <span style="height: 88%" />
          <span style="height: 72%" />
        </div>

        <div class="dashboard-table">
          <div class="dashboard-row dashboard-row--head">
            <span>Chi nhánh</span>
            <span>Tồn kho</span>
            <span>Trạng thái</span>
          </div>
          <div class="dashboard-row">
            <span>Quận 1</span>
            <span>92%</span>
            <span class="good">Tốt</span>
          </div>
          <div class="dashboard-row">
            <span>Thủ Đức</span>
            <span>81%</span>
            <span class="watch">Theo dõi</span>
          </div>
          <div class="dashboard-row">
            <span>Bình Thạnh</span>
            <span>89%</span>
            <span class="good">Tốt</span>
          </div>
        </div>
      </div>
    </div>
  )
}
