---
import { formatNewsDate } from '../lib/newsDate';
import { resolveArticleImage } from '../lib/articleSeo';

const { posts = [] } = Astro.props;
---

<section class="section knowledge-section" id="tin-tuc">
  <div class="container">
    <div class="section-heading knowledge-heading">
      <h2>Kiến thức dành cho nhà thuốc.</h2>
      <a href="/vi/tin-tuc/">Xem tất cả bài viết →</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="knowledge-grid">
          {posts.map((post) => (
            <article class="knowledge-card">
              <a class="knowledge-thumb" href={`/vi/tin-tuc/${post.id}/`} aria-hidden="true" tabindex="-1">
                <img src={resolveArticleImage(post.id, post.data.image)} alt="" loading="lazy" decoding="async" />
              </a>
              <p class="news-meta">{formatNewsDate(post.data.pubDate)}</p>
              <h3>
                <a href={`/vi/tin-tuc/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      ) : (
        <p class="section-intro">Chưa có bài tin mới — vui lòng quay lại sau.</p>
      )
    }

  </div>
</section>
