---
const trustCards = [
  { icon: 'clock', title: '15 phút', desc: 'Hoàn thành đánh giá' },
  { icon: 'questions', title: '30 câu hỏi', desc: 'Đánh giá toàn diện' },
  { icon: 'pdf', title: 'Báo cáo PDF', desc: 'Tư vấn chuyên sâu' },
  { icon: 'consult', title: 'Tư vấn miễn phí', desc: 'Cùng chuyên gia' },
];
---

<section class="trust-section" aria-label="Lợi ích đánh giá miễn phí">
  <div class="trust-grid">
    {
      trustCards.map((card) => (
        <article class="trust-card">
          <span class={`trust-icon trust-icon--${card.icon}`} aria-hidden="true">
            {card.icon === 'clock' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
                <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            )}
            {card.icon === 'questions' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.8" />
                <path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            )}
            {card.icon === 'pdf' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.8" />
                <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.8" />
              </svg>
            )}
            {card.icon === 'consult' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4v-4H6a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.8" />
              </svg>
            )}
          </span>
          <div>
            <strong>{card.title}</strong>
            <span>{card.desc}</span>
          </div>
        </article>
      ))
    }
  </div>
</section>
