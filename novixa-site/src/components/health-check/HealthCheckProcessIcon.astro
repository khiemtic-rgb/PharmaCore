---
interface Props {
  name: 'questions' | 'brain' | 'pdf' | 'expert' | 'target';
}

const { name } = Astro.props;
---

<span class="hc-process__icon" aria-hidden="true">
  {name === 'questions' && (
    <svg viewBox="0 0 48 56" fill="none" class="hc-process__svg">
      <rect x="10" y="6" width="28" height="44" rx="4" stroke="#2563eb" stroke-width="2" />
      <path d="M14 6v6h20V6" stroke="#2563eb" stroke-width="2" />
      <circle cx="16" cy="9" r="1.25" fill="#2563eb" />
      <circle cx="20" cy="9" r="1.25" fill="#2563eb" />
      <path d="M16 22h14M16 28h14M16 34h10" stroke="#93c5fd" stroke-width="2" stroke-linecap="round" />
      <path d="M14 20l2 2 4-4" stroke="#19c37d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M14 26l2 2 4-4" stroke="#19c37d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
  {name === 'brain' && (
    <svg viewBox="0 0 48 56" fill="none" class="hc-process__svg">
      <path d="M18 14c-4 0-7 3-7 7v2c-3 0-5 2-5 5s2 5 5 5v2c0 4 3 7 7 7" stroke="#2563eb" stroke-width="2" stroke-linecap="round" />
      <path d="M30 14c4 0 7 3 7 7v2c3 0 5 2 5 5s-2 5-5 5v2c0 4-3 7-7 7" stroke="#2563eb" stroke-width="2" stroke-linecap="round" />
      <text x="24" y="34" text-anchor="middle" fill="#2563eb" font-size="11" font-weight="800" font-family="Inter,system-ui,sans-serif">AI</text>
    </svg>
  )}
  {name === 'pdf' && (
    <svg viewBox="0 0 48 56" fill="none" class="hc-process__svg">
      <path d="M12 6h18l10 10v34a2 2 0 01-2 2H12a2 2 0 01-2-2V8a2 2 0 012-2z" stroke="#2563eb" stroke-width="2" />
      <path d="M30 6v10h10" stroke="#2563eb" stroke-width="2" />
      <rect x="16" y="30" width="16" height="8" rx="2" fill="#ef4444" />
      <text x="24" y="36.5" text-anchor="middle" fill="#fff" font-size="6" font-weight="800" font-family="Inter,system-ui,sans-serif">PDF</text>
      <path d="M16 22h14M16 26h10" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}
  {name === 'expert' && (
    <svg viewBox="0 0 48 56" fill="none" class="hc-process__svg">
      <path d="M14 30c0-6 4.5-10 10-10s10 4 10 10" stroke="#2563eb" stroke-width="2.25" stroke-linecap="round" />
      <path d="M8 28c0-5 3.5-8 8-8" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round" />
      <rect x="4" y="26" width="10" height="14" rx="5" fill="#2563eb" />
      <path d="M34 24c0-5 3.5-8 8-8" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round" />
      <rect x="34" y="22" width="10" height="14" rx="5" fill="#2563eb" />
      <path d="M18 40h12" stroke="#2563eb" stroke-width="2" stroke-linecap="round" />
      <rect x="16" y="40" width="16" height="5" rx="2.5" fill="#2563eb" />
    </svg>
  )}
  {name === 'target' && (
    <svg viewBox="0 0 48 56" fill="none" class="hc-process__svg">
      <circle cx="24" cy="30" r="14" stroke="#2563eb" stroke-width="2" />
      <circle cx="24" cy="30" r="8" stroke="#2563eb" stroke-width="2" />
      <circle cx="24" cy="30" r="3" fill="#2563eb" />
      <path d="M24 30 L36 18" stroke="#2563eb" stroke-width="2" stroke-linecap="round" />
      <path d="M36 18 L33 18 L36 21 Z" fill="#2563eb" />
    </svg>
  )}
</span>
