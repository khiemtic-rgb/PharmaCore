---
import { t } from '../i18n';

const m = t('vi');
const c = m.contact;
const co = m.company;
const year = new Date().getFullYear();
const hasFacebook = Boolean(c.facebookUrl?.trim());
const zaloUrl = c.zaloPhone ? `https://zalo.me/${c.zaloPhone}` : '/vi/lien-he/';

const columns = [
  {
    title: 'Nền tảng',
    links: [
      { href: '/vi/', label: 'Overview' },
      { href: '/vi/#ecosystem', label: 'Architecture' },
      { href: '/vi/giai-phap/ai-copilot/', label: 'AI Platform' },
      { href: '/vi/#enterprise', label: 'API & Integration' },
      { href: '/vi/#enterprise', label: 'Security' },
    ],
  },
  {
    title: 'Giải pháp',
    links: [
      { href: '/vi/giai-phap/', label: 'Novixa Pharmacy' },
      { href: '/vi/#connect', label: 'Novixa Connect' },
      { href: '/vi/#clinic', label: 'Novixa Clinic' },
      { href: '/vi/giai-phap/app-khach-hang/', label: 'Customer App' },
    ],
  },
  {
    title: 'Tài nguyên',
    links: [
      { href: '/vi/tai-lieu/', label: 'Tài liệu' },
      { href: '/vi/tin-tuc/', label: 'Blog' },
      { href: 'https://kittech.vn/vi/', label: 'Knowledge' },
      { href: '/vi/giai-phap/', label: 'Giải pháp' },
      { href: '/vi/#enterprise', label: 'API' },
    ],
  },
  {
    title: 'Về Novixa',
    links: [
      { href: '/vi/ve-chung-toi/', label: 'Giới thiệu' },
      { href: '/vi/#clinic', label: 'Đối tác' },
      { href: '/vi/lien-he/', label: 'Tuyển dụng' },
      { href: '/vi/lien-he/', label: 'Liên hệ' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/vi/" class="footer-logo">
        <span class="logo-mark" aria-hidden="true">N</span>
        <span class="footer-logo__text">
          <strong>NOVIXA</strong>
          <small>Healthcare Platform</small>
        </span>
      </a>
      <p>
        Nền tảng kết nối và vận hành hệ sinh thái Nhà thuốc – Phòng khám – Bệnh nhân.
      </p>
      <div class="footer-social">
        {
          hasFacebook && (
            <a
              class="footer-social__btn"
              href={c.facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M14.5 8.5H16V6h-1.7C12.3 6 11 7.4 11 9.3V11H9v2.5h2V18h2.7v-4.5H16L16.4 11H13.7V9.5c0-.6.3-1 1-1z"
                />
              </svg>
            </a>
          )
        }
        <a class="footer-social__btn" href={zaloUrl} target="_blank" rel="noopener noreferrer" aria-label="Zalo">
          <span aria-hidden="true">Z</span>
        </a>
        <a class="footer-social__btn" href="/vi/lien-he/" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M19.6 7.2a2.3 2.3 0 00-1.6-1.6C16.5 5.2 12 5.2 12 5.2s-4.5 0-6 .4A2.3 2.3 0 004.4 7.2 24 24 0 004 12a24 24 0 00.4 4.8 2.3 2.3 0 001.6 1.6c1.5.4 6 .4 6 .4s4.5 0 6-.4a2.3 2.3 0 001.6-1.6A24 24 0 0020 12a24 24 0 00-.4-4.8zM10.2 14.8V9.2L14.8 12l-4.6 2.8z"
            />
          </svg>
        </a>
        <a class="footer-social__btn" href="/vi/lien-he/" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M7.2 9.5H4.8V19h2.4V9.5zM6 4.8a1.4 1.4 0 100 2.8A1.4 1.4 0 006 4.8zM19.2 19h-2.4v-4.8c0-1.3-.5-2.1-1.6-2.1-.9 0-1.4.6-1.6 1.2-.1.2-.1.5-.1.8V19h-2.4V9.5h2.4v1.3c.4-.7 1.2-1.6 2.9-1.6 2.1 0 3.6 1.4 3.6 4.3V19z"
            />
          </svg>
        </a>
      </div>
      <div class="footer-legal">
        <p class="footer-provider">
          {co.providerLabel}{' '}
          <a class="footer-link footer-link--inline" href={co.providerUrl} target="_blank" rel="noopener noreferrer">
            {co.providerName}
          </a>
        </p>
        <p>{co.legalName}</p>
        <p>{co.addressShort}</p>
      </div>
    </div>

    {
      columns.map((column) => (
        <div class="footer-column">
          <h2>{column.title}</h2>
          {column.links.map((link) => (
            <a
              class="footer-link"
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      ))
    }

    <div class="footer-column footer-news">
      <p class="footer-news__title">Nhận tin tức mới nhất từ Novixa</p>
      <form
        class="footer-newsletter"
        action={`https://formsubmit.co/${encodeURIComponent(c.emailAddress)}`}
        method="POST"
      >
        <input type="hidden" name="_subject" value="Novixa newsletter signup" />
        <input type="hidden" name="_captcha" value="false" />
        <label class="sr-only" for="footer-email">Email</label>
        <input
          id="footer-email"
          name="email"
          type="email"
          required
          placeholder="Email của bạn"
          autocomplete="email"
        />
        <button type="submit" aria-label="Đăng ký nhận tin">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M4 8.5l7.2 3.6L20 6.5 11.2 19l-.8-5.2L4 8.5z"
              stroke="#fff"
              stroke-width="1.8"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      </form>
      <p class="footer-copy">© {year} Novixa. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0a1b2e;
    color: #d9e6f3;
    padding: clamp(3rem, 7vw, 4.5rem) 0 2.25rem;
    font-size: 0.9rem;
  }

  .footer-grid {
    display: grid;
    gap: 2rem 1.35rem;
    grid-template-columns: 1.4fr repeat(4, minmax(0, 0.92fr)) 1.15fr;
    align-items: start;
  }

  .footer-brand p {
    max-width: 34ch;
    margin: 1rem 0 0;
    color: #a9bfd5;
    line-height: 1.55;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: #fff;
    text-decoration: none;
  }

  .footer-logo__text {
    display: grid;
    gap: 0.05rem;
    line-height: 1.1;
  }

  .footer-logo__text strong {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .footer-logo__text small {
    color: #b7c9db;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .logo-mark {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: #16c784;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .footer-legal {
    margin-top: 1rem;
    font-size: 0.72rem;
    color: #7f94a8;
  }

  .footer-legal p {
    margin: 0.12rem 0;
    max-width: none;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.15rem;
  }

  .footer-social__btn {
    display: grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 999px;
    background: #3d6ea8;
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 800;
    transition: background 150ms ease, transform 150ms ease;
  }

  .footer-social__btn:hover {
    background: #16c784;
    transform: translateY(-1px);
  }

  .footer-social__btn svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .footer-column h2 {
    margin: 0 0 0.9rem;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .footer-news__title {
    margin: 0 0 0.85rem;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .footer-newsletter {
    display: flex;
    align-items: stretch;
    overflow: hidden;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  }

  .footer-newsletter input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: #fff;
    color: #0b1f33;
    padding: 0.7rem 0.85rem;
    font-size: 0.88rem;
  }

  .footer-newsletter input:focus {
    outline: none;
  }

  .footer-newsletter button {
    display: grid;
    place-items: center;
    border: 0;
    width: 2.75rem;
    background: #16c784;
    color: #fff;
    cursor: pointer;
    transition: background 150ms ease;
  }

  .footer-newsletter button:hover {
    background: #12a86e;
  }

  .footer-newsletter button svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .footer-link {
    display: block;
    color: #a9bfd5;
    text-decoration: none;
    margin: 0.4rem 0;
  }

  .footer-link:hover {
    color: #16c784;
  }

  .footer-link--inline {
    display: inline;
    margin: 0;
  }

  .footer-copy {
    margin: 1rem 0 0;
    color: #7f94a8;
    font-size: 0.78rem;
  }

  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
