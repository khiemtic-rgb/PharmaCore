---
import { resolveArticleImage } from '../lib/articleSeo';
import { formatNewsDate, isNewsRecent } from '../lib/newsDate';
import NewsNewBadge from './NewsNewBadge.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  newLabel: string;
  image?: string;
  showDescription?: boolean;
}

const { slug, title, description, pubDate, newLabel, image: imageProp, showDescription = true } =
  Astro.props;
const href = `/vi/tin-tuc/${slug}/`;
const image = resolveArticleImage(slug, imageProp);
---

<li class="news-list-item">
  <a class="news-thumb" href={href} aria-hidden="true" tabindex="-1">
    <img
      src={image}
      alt=""
      width="168"
      height="88"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="news-list-body">
    <div class="news-title-row">
      <a href={href}>{title}</a>
      <NewsNewBadge show={isNewsRecent(pubDate)} label={newLabel} />
    </div>
    <p class="news-meta">{formatNewsDate(pubDate)}</p>
    {showDescription && <p class="news-desc">{description}</p>}
  </div>
</li>
