---
const steps = [
  { title: 'Trả lời 30 câu hỏi', desc: 'Khoảng 7 phút • Đánh giá toàn diện hoạt động nhà thuốc', icon: 'questions' },
  { title: 'AI phân tích & chấm điểm', desc: 'Đánh giá hiện trạng, rủi ro và cơ hội cải thiện', icon: 'brain' },
  { title: 'Nhận báo cáo tư vấn chuyên sâu', desc: 'Dashboard • SWOT • Roadmap • AI Insight • Tư vấn 1-1', icon: 'pdf' },
  { title: 'Tư vấn cùng chuyên gia', desc: 'Phân tích kết quả và xây dựng kế hoạch cải thiện', icon: 'expert' },
  { title: 'Lộ trình chuyển đổi', desc: 'Đề xuất giải pháp phù hợp với quy mô và mục tiêu của nhà thuốc', icon: 'novixa' },
];

const checklist = [
  'Biết điểm mạnh và điểm yếu',
  'Phát hiện vấn đề làm giảm doanh thu',
  'Xác định rủi ro tồn kho & vận hành',
  'Nhận lộ trình cải thiện',
];

const benefits = [
  { icon: 'trending', title: 'Tăng doanh thu', desc: 'Nhờ kiểm soát tốt & chăm sóc khách hàng' },
  { icon: 'shield', title: 'Giảm thất thoát', desc: 'Kiểm soát tồn kho, hạn dùng, nhập hàng' },
  { icon: 'clock', title: 'Tiết kiệm thời gian', desc: 'Quy trình chuẩn, quản lý mọi lúc mọi nơi' },
  { icon: 'chart', title: 'Ra quyết định dễ dàng', desc: 'Báo cáo trực quan, dữ liệu chính xác' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="hp-health" id="danh-gia" aria-labelledby="health-title">
  <div class="container">
    <div class="hp-health__card">
      <div class="hp-health__grid">
        <div class="hp-health__content">
          <span class="hp-health__badge">AI HEALTH CHECK</span>
          <h2 class="hp-health__title" id="health-title">
            Nhà thuốc của bạn<br />đang gặp vấn đề ở đâu?
          </h2>
          <ul class="hp-health__list">
            {
              checklist.map((item) => (
                <li>
                  <span class="hp-health__check" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 8.5L6.5 12L13 4" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
          <a class="hp-health__cta" href={assessmentUrl}>
            Bắt đầu đánh giá ngay
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <div class="hp-flow" aria-label="Quy trình đánh giá">
          {
            steps.map((step, i) => (
              <>
                {i > 0 && (
                  <span class="hp-flow__connector" aria-hidden="true">
                    <svg viewBox="0 0 24 8" fill="none">
                      <line x1="0" y1="4" x2="18" y2="4" stroke="#16c784" stroke-width="1.5" stroke-dasharray="3 3" />
                      <path d="M20 1l3 3-3 3" stroke="#16c784" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                )}
                <div class="hp-flow__step">
                  <div class="hp-flow__card">
                    <span class="hp-flow__num">{i + 1}</span>
                    <span class:list={['hp-flow__icon', step.icon === 'novixa' && 'hp-flow__icon--novixa']} aria-hidden="true">
                      {step.icon === 'questions' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="5" y="3" width="14" height="18" rx="2" />
                          <path d="M9 3v2M15 3v2" />
                          <path d="M8.5 9.5l1.5 1.5 3-3" />
                          <path d="M8 14h8M8 17h5" />
                        </svg>
                      )}
                      {step.icon === 'brain' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 5a3 3 0 00-3 3v1a2 2 0 01-2 2 2 2 0 000 4 2 2 0 012 2v1a3 3 0 003 3" />
                          <path d="M15 5a3 3 0 013 3v1a2 2 0 012 2 2 2 0 010 4 2 2 0 01-2 2v1a3 3 0 01-3 3" />
                          <path d="M9 8h6M10 12h4" />
                        </svg>
                      )}
                      {step.icon === 'pdf' && (
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5" />
                          <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.5" />
                          <rect x="7.5" y="13" width="9" height="4.5" rx="1" fill="#ef4444" />
                          <text x="12" y="16.2" text-anchor="middle" fill="#fff" font-size="3.2" font-weight="700" font-family="Inter,sans-serif">PDF</text>
                        </svg>
                      )}
                      {step.icon === 'expert' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="9" r="3" />
                          <path d="M6 19c0-2.8 2.7-5 6-5s6 2.2 6 5" />
                          <path d="M4 12.5a8 8 0 0116 0" />
                          <path d="M6 12.5v1.5a2 2 0 002 2h1" />
                          <path d="M18 12.5v1.5a2 2 0 01-2 2h-1" />
                        </svg>
                      )}
                      {step.icon === 'novixa' && (
                        <img src="/images/logo.png" alt="" width="28" height="28" decoding="async" />
                      )}
                    </span>
                  </div>
                  <span class="hp-flow__title">{step.title}</span>
                  <span class="hp-flow__desc">{step.desc}</span>
                </div>
              </>
            ))
          }
        </div>
      </div>

      <div class="hp-health__benefits" aria-label="Lợi ích sau đánh giá">
        {
          benefits.map((b) => (
            <article class="hp-health__benefit">
              <span class="hp-health__benefit-icon" aria-hidden="true">
                {b.icon === 'trending' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 17l6-6 4 4 8-10" />
                    <path d="M14 5h7v7" />
                  </svg>
                )}
                {b.icon === 'shield' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                )}
                {b.icon === 'clock' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                  </svg>
                )}
                {b.icon === 'chart' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <path d="M4 19V5" />
                    <path d="M4 19h16" />
                    <rect x="7" y="10" width="3" height="6" rx="0.5" />
                    <rect x="12" y="7" width="3" height="9" rx="0.5" />
                    <rect x="17" y="12" width="3" height="4" rx="0.5" />
                  </svg>
                )}
              </span>
              <div class="hp-health__benefit-text">
                <strong>{b.title}</strong>
                <span>{b.desc}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
