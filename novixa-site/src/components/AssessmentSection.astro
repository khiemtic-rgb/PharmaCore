---
const checklist = [
  'Biết điểm mạnh và điểm yếu',
  'Phát hiện vấn đề làm giảm doanh thu',
  'Xác định rủi ro tồn kho',
  'Nhận lộ trình cải thiện phù hợp',
];

const steps = [
  { title: 'Trả lời 30 câu hỏi', desc: 'Khoảng 15 phút', icon: 'quiz' },
  { title: 'AI phân tích & chấm điểm', desc: 'Tự động & chính xác', icon: 'chart' },
  { title: 'Nhận báo cáo PDF', desc: 'Tư vấn chuyên sâu', icon: 'pdf' },
  { title: 'Tư vấn cùng chuyên gia', desc: '1-1 miễn phí', icon: 'consult' },
  { title: 'Triển khai Novixa', desc: 'Lộ trình rõ ràng', icon: 'launch' },
];

const features = [
  { icon: 'clock', title: '15 phút', desc: 'Hoàn thành đánh giá' },
  { icon: 'questions', title: '30 câu hỏi', desc: 'Đánh giá toàn diện' },
  { icon: 'pdf', title: 'Báo cáo PDF', desc: 'Tư vấn chuyên sâu' },
  { icon: 'consult', title: 'Tư vấn miễn phí', desc: 'Cùng chuyên gia' },
  { icon: 'lock', title: 'Bảo mật tuyệt đối', desc: 'Thông tin được bảo vệ' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="assessment-section" id="danh-gia">
  <div class="assessment-card">
    <div class="assessment-grid">
      <div class="assessment-content">
        <h2>Nhà thuốc của bạn đang gặp vấn đề ở đâu?</h2>
        <p class="assessment-subtitle">
          Chỉ với 15 phút, bạn sẽ nhận được báo cáo tư vấn giúp:
        </p>
        <ul class="assessment-checklist">
          {
            checklist.map((item) => (
              <li>
                <span class="check-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8.5L6.5 12L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                {item}
              </li>
            ))
          }
        </ul>
        <a class="btn btn-green assessment-cta" href={assessmentUrl}>
          Bắt đầu đánh giá miễn phí
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <div class="assessment-steps" aria-label="Quy trình đánh giá">
        {
          steps.map((step, i) => (
            <div class="assessment-step-wrap">
              <div class="assessment-step">
                <span class="step-icon-wrap">
                  <span class={`step-icon step-icon--${step.icon}`} aria-hidden="true">
                    {step.icon === 'quiz' && (
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M8 4h8a2 2 0 012 2v14l-4-3-4 3-4-3-4 3V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.6" />
                        <path d="M9 9h6M9 13h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                      </svg>
                    )}
                    {step.icon === 'chart' && (
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 4v16M4 12a8 8 0 1016 0" stroke="currentColor" stroke-width="1.6" />
                        <path d="M12 12l5-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                      </svg>
                    )}
                    {step.icon === 'pdf' && (
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.6" />
                        <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.6" />
                      </svg>
                    )}
                    {step.icon === 'consult' && (
                      <svg viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.6" />
                        <path d="M6 20c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.6" />
                      </svg>
                    )}
                    {step.icon === 'launch' && (
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M7 4h10v16H7V4z" fill="url(#stepNovixaGrad)" />
                        <defs>
                          <linearGradient id="stepNovixaGrad" x1="7" y1="4" x2="17" y2="20">
                            <stop stop-color="#16c784" />
                            <stop offset="1" stop-color="#0f4c81" />
                          </linearGradient>
                        </defs>
                      </svg>
                    )}
                  </span>
                  <span class="step-num">{i + 1}</span>
                </span>
                <div class="step-body">
                  <strong>{step.title}</strong>
                  <span>{step.desc}</span>
                </div>
              </div>
              {i < steps.length - 1 && <span class="step-connector" aria-hidden="true" />}
            </div>
          ))
        }
      </div>
    </div>

    <div class="assessment-features">
      {
        features.map((f) => (
          <div class="assessment-feature">
            <span class={`feature-icon feature-icon--${f.icon}`} aria-hidden="true">
              {f.icon === 'clock' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
                  <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
              {f.icon === 'questions' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.8" />
                  <path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
              {f.icon === 'pdf' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.8" />
                  <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.8" />
                </svg>
              )}
              {f.icon === 'consult' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4v-4H6a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.8" />
                </svg>
              )}
              {f.icon === 'lock' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="5" y="10" width="14" height="11" rx="2" stroke="currentColor" stroke-width="1.8" />
                  <path d="M8 10V7a4 4 0 018 0v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
            </span>
            <div>
              <strong>{f.title}</strong>
              <span>{f.desc}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
