---
const plans = [
  {
    name: 'Khởi đầu',
    desc: 'Phù hợp nhà thuốc độc lập 1 điểm bán.',
    features: ['POS & Kho FEFO', 'CRM cơ bản', 'Dashboard', 'Hỗ trợ triển khai'],
  },
  {
    name: 'Phát triển',
    desc: 'Cho chuỗi nhỏ và nhà thuốc đang mở rộng.',
    features: ['Đa chi nhánh', 'App khách hàng', 'Báo cáo nâng cao', 'AI Copilot'],
    featured: true,
  },
  {
    name: 'Doanh nghiệp',
    desc: 'Tùy chỉnh theo quy mô và quy trình riêng.',
    features: ['Tích hợp mở rộng', 'Phân quyền nâng cao', 'SLA ưu tiên', 'Tư vấn 1-1'],
  },
];
---

<section class="hp-pricing" id="bang-gia">
  <div class="container">
    <div class="hp-pricing__head">
      <h2>Bảng giá linh hoạt</h2>
      <p>Bắt đầu với đánh giá miễn phí — nhận tư vấn và báo giá phù hợp quy mô nhà thuốc của bạn.</p>
    </div>

    <div class="hp-pricing__grid">
      {
        plans.map((plan) => (
          <article class:list={['hp-pricing__card', { 'hp-pricing__card--featured': plan.featured }]}>
            <h3>{plan.name}</h3>
            <p class="hp-pricing__desc">{plan.desc}</p>
            <ul>
              {plan.features.map((f) => (
                <li>{f}</li>
              ))}
            </ul>
            <a class="hp-pricing__btn" href="https://survey.novixa.vn">Nhận tư vấn & báo giá</a>
          </article>
        ))
      }
    </div>
  </div>
</section>
