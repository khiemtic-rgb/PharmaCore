---
import DashboardPreview from './DashboardPreview.astro';
---

<section class="section app-section" id="app-khach-hang">
  <div class="container app-section-grid">
    <div class="section-heading">
      <p class="eyebrow">App khách hàng</p>
      <h2>Chăm sóc khách hàng mọi lúc.</h2>
      <p>
        Khách hàng đặt thuốc, nhận nhắc uống thuốc và tích điểm thân thiết ngay trên điện thoại.
      </p>
    </div>
    <div class="app-visual" aria-label="Mockup ứng dụng khách hàng Novixa">
      <div class="phone-frame phone-frame--large">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <DashboardPreview compact variant="phone" />
        </div>
      </div>
    </div>
  </div>
</section>
