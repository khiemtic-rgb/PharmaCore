---
import DashboardPreview from './DashboardPreview.astro';

const chips = [
  { label: 'POS', icon: 'pos' },
  { label: 'Kho hàng', icon: 'warehouse' },
  { label: 'Khách hàng', icon: 'customers' },
  { label: 'Báo cáo', icon: 'reports' },
  { label: 'App khách hàng', icon: 'app' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="hero" id="hero">
  <div class="hero-shape" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--tl" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--br" aria-hidden="true"></div>
  <div class="hero-grid">
    <div class="hero-content motion-in">
      <p class="eyebrow">Giải pháp quản trị nhà thuốc toàn diện</p>
      <h1>Vận hành nhà thuốc <span>thông minh hơn</span> mỗi ngày.</h1>
      <p class="hero-lead">
        Novixa giúp bạn kiểm soát tồn kho, tăng doanh thu, giữ chân khách hàng
        và vận hành hiệu quả hơn trên một nền tảng duy nhất.
      </p>
      <div class="hero-actions">
        <a class="btn btn-green" href="/vi/lien-he">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.4" />
            <path d="M2 6.5h12M5 1.5v2M11 1.5v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
          Đăng ký Demo
        </a>
        <a class="btn btn-assess" href={assessmentUrl}>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4" />
            <path d="M8 5v3.5l2 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
          <span class="btn-assess-text">
            <strong>Đánh giá nhà thuốc miễn phí</strong>
            <small>Nhận báo cáo tư vấn chi tiết</small>
          </span>
        </a>
      </div>
      <div class="hero-chips" aria-label="Các năng lực chính của Novixa">
        {
          chips.map((chip) => (
            <span class="hero-chip">
              <span class={`hero-chip-icon hero-chip-icon--${chip.icon}`} aria-hidden="true">
                {chip.icon === 'pos' && (
                  <svg viewBox="0 0 20 20" fill="none">
                    <rect x="3" y="5" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    <path d="M7 9h6M7 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                )}
                {chip.icon === 'warehouse' && (
                  <svg viewBox="0 0 20 20" fill="none">
                    <path d="M3 8l7-4 7 4v8H3V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                    <path d="M8 16v-5h4v5" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {chip.icon === 'customers' && (
                  <svg viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5" />
                    <path d="M4 16c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                )}
                {chip.icon === 'reports' && (
                  <svg viewBox="0 0 20 20" fill="none">
                    <path d="M4 16V8l4-2 4 3 4-2v9" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  </svg>
                )}
                {chip.icon === 'app' && (
                  <svg viewBox="0 0 20 20" fill="none">
                    <rect x="6" y="2" width="8" height="16" rx="2" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="10" cy="15" r="0.8" fill="currentColor" />
                  </svg>
                )}
              </span>
              {chip.label}
            </span>
          ))
        }
      </div>
    </div>

    <div class="hero-visual motion-in motion-delay">
      <div class="hero-mockup-wrap" aria-label="Dashboard Novixa">
        <DashboardPreview compact variant="hero" />
        <div class="phone-frame" aria-label="Novixa trên điện thoại">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <DashboardPreview compact variant="phone" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
