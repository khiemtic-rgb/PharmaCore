---
import DashboardPreview from './DashboardPreview.astro';

const tags = [
  { label: 'POS', icon: 'pos' },
  { label: 'Kho FEFO', icon: 'warehouse' },
  { label: 'CRM', icon: 'customers' },
  { label: 'Dashboard', icon: 'reports' },
  { label: 'App khách hàng', icon: 'app' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="hp-hero" id="hero" aria-labelledby="hero-title">
  <div class="hp-hero__content">
    <p class="hp-hero__badge">Giải pháp quản trị nhà thuốc toàn diện</p>
    <h1 class="hp-hero__title" id="hero-title">
      Vận hành nhà thuốc<br />
      <span>thông minh hơn</span> mỗi ngày.
    </h1>
    <p class="hp-hero__desc">
      Novixa giúp bạn kiểm soát tồn kho, tăng doanh thu, giữ chân khách hàng
      và vận hành nhà thuốc hiệu quả hơn trên một nền tảng duy nhất.
    </p>
    <div class="hp-hero__actions">
      <a class="hp-btn hp-btn--primary" href={assessmentUrl}>
        <span class="hp-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </span>
        <span class="hp-btn__stack">
          <strong>Đánh giá miễn phí</strong>
          <small>10 đặc điểm quản trị cần có</small>
        </span>
      </a>
      <a class="hp-btn hp-btn--secondary" href="/vi/lien-he">
        <span class="hp-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
        </span>
        <span class="hp-btn__stack">
          <strong>Đăng ký Demo</strong>
          <small>Trải nghiệm nền tảng</small>
        </span>
      </a>
    </div>
    <div class="hp-hero__tags" aria-label="Các module chính">
      {
        tags.map((tag) => (
          <span class="hp-tag">
            <span class="hp-tag__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                {tag.icon === 'pos' && (
                  <>
                    <rect x="3" y="6" width="18" height="12" rx="2" />
                    <path d="M7 11h10M7 15h6" />
                  </>
                )}
                {tag.icon === 'warehouse' && (
                  <>
                    <path d="M3 9l9-5 9 5v11H3V9z" />
                    <path d="M9 20v-6h6v6" />
                  </>
                )}
                {tag.icon === 'customers' && (
                  <>
                    <circle cx="12" cy="8" r="3.5" />
                    <path d="M5 20c0-3.5 3.1-6 7-6s7 2.5 7 6" />
                  </>
                )}
                {tag.icon === 'reports' && (
                  <>
                    <path d="M4 19V9l4-2 4 3 4-2v11" />
                    <path d="M4 19h16" />
                  </>
                )}
                {tag.icon === 'app' && (
                  <>
                    <rect x="7" y="2" width="10" height="20" rx="2" />
                    <circle cx="12" cy="18" r="0.75" fill="currentColor" stroke="none" />
                  </>
                )}
              </svg>
            </span>
            {tag.label}
          </span>
        ))
      }
    </div>
  </div>

  <div class="hp-hero__visual" aria-hidden="true">
    <div class="hp-hero__mockup">
      <DashboardPreview compact variant="hero" />
      <div class="hp-hero__phone">
        <div class="hp-hero__phone-notch"></div>
        <div class="hp-hero__phone-screen">
          <DashboardPreview compact variant="phone" />
        </div>
      </div>
    </div>
  </div>
</section>
