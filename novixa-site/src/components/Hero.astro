---
import DashboardPreview from './DashboardPreview.astro';

const tags = [
  { label: 'POS', icon: 'pos' },
  { label: 'Kho FEFO', icon: 'warehouse' },
  { label: 'CRM', icon: 'customers' },
  { label: 'Dashboard', icon: 'reports' },
  { label: 'App khách hàng', icon: 'app' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="hp-hero" id="hero" aria-labelledby="hero-title">
  <div class="hp-hero__content hp-reveal">
    <p class="hp-hero__badge">Giải pháp quản trị nhà thuốc toàn diện</p>
    <h1 class="hp-hero__title" id="hero-title">
      Vận hành nhà thuốc<br />
      <span>thông minh hơn</span><br />
      mỗi ngày.
    </h1>
    <p class="hp-hero__desc">
      Novixa giúp bạn kiểm soát tồn kho, tăng doanh thu, giữ chân khách hàng
      và vận hành nhà thuốc hiệu quả hơn trên một nền tảng duy nhất.
    </p>
    <div class="hp-hero__actions">
      <a class="hp-btn hp-btn--primary" href={assessmentUrl}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-linecap="round" />
        </svg>
        <span class="hp-btn__stack">
          <strong>Đánh giá miễn phí</strong>
          <small>Nhận báo cáo tư vấn chi tiết</small>
        </span>
      </a>
      <a class="hp-btn hp-btn--secondary" href="/vi/lien-he">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="5" width="18" height="16" rx="2" />
          <path d="M3 10h18M8 3v4M16 3v4" stroke-linecap="round" />
        </svg>
        <span class="hp-btn__stack">
          <strong>Đăng ký Demo</strong>
          <small>Trải nghiệm nền tảng</small>
        </span>
      </a>
    </div>
    <div class="hp-hero__tags" aria-label="Các module chính">
      {
        tags.map((tag) => (
          <span class="hp-tag">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              {tag.icon === 'pos' && (
                <>
                  <rect x="3" y="5" width="14" height="10" rx="1.5" />
                  <path d="M7 9h6M7 12h4" stroke-linecap="round" />
                </>
              )}
              {tag.icon === 'warehouse' && (
                <>
                  <path d="M3 8l7-4 7 4v8H3V8z" stroke-linejoin="round" />
                  <path d="M8 16v-5h4v5" />
                </>
              )}
              {tag.icon === 'customers' && (
                <>
                  <circle cx="10" cy="7" r="3" />
                  <path d="M4 16c0-3 2.7-5 6-5s6 2 6 5" stroke-linecap="round" />
                </>
              )}
              {tag.icon === 'reports' && (
                <path d="M4 16V8l4-2 4 3 4-2v9" stroke-linejoin="round" />
              )}
              {tag.icon === 'app' && (
                <>
                  <rect x="6" y="2" width="8" height="16" rx="2" />
                  <circle cx="10" cy="15" r="0.8" fill="currentColor" stroke="none" />
                </>
              )}
            </svg>
            {tag.label}
          </span>
        ))
      }
    </div>
  </div>

  <div class="hp-hero__visual hp-reveal" aria-hidden="true">
    <div class="hp-hero__mockup">
      <DashboardPreview compact variant="hero" />
      <div class="hp-hero__phone">
        <div class="hp-hero__phone-notch"></div>
        <div class="hp-hero__phone-screen">
          <DashboardPreview compact variant="phone" />
        </div>
      </div>
    </div>
  </div>
</section>
